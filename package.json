{
  "name": "n8n-nodes-vodafone",
  "version": "1.2.0",
  "description": "n8n community node for downloading Vodafone Germany invoices",
  "license": "MIT",
  "homepage": "https://github.com/danez/n8n-nodes-vodafone#readme",
  "keywords": [
    "n8n-community-node-package"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.8.0",
  "author": {
    "name": "Daniel Tschinder",
    "email": "n8n.vodafone@tschinder.de",
    "url": "http://github.com/danez"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danez/n8n-nodes-vodafone.git"
  },
  "scripts": {
    "build": "rimraf dist/ && n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "changesets-release": "pnpm build && changeset publish",
    "changesets-version": "changeset version && pnpm install --lockfile-only"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/VodafoneApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Vodafone/Vodafone.node.js"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@n8n/node-cli": "0.36.1",
    "eslint": "9.39.4",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
